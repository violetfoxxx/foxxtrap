            width: 100%; 
            padding: 14px; 
            margin: 10px 0; 
            background: rgba(255, 0, 127, 0.02); 
            border: 1px solid var(--neon-pink); 
            color: #fff; 
            cursor: pointer; 
            text-transform: uppercase; 
            font-family: inherit; 
            font-size: 13px;
